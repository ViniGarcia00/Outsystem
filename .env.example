# =============================================================================
# Outmat Propostas — variáveis de ambiente
# Copie este arquivo para `.env` e ajuste os valores conforme o ambiente.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de dados (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://usuario:senha@localhost:5432/outmat_propostas?schema=public"

# -----------------------------------------------------------------------------
# Armazenamento de arquivos
# TODOS os caminhos são CONFIGURÁVEIS — nunca fixos no código.
# No Windows Server 2019 use caminhos absolutos, ex.: D:\\OutmatPropostas\\storage
# As pastas específicas (PDF/UPLOAD/BACKUP/LOG) são opcionais; quando ausentes,
# são derivadas de STORAGE_PATH. Nenhuma pasta é criada automaticamente nesta fase.
# -----------------------------------------------------------------------------
STORAGE_PATH="./storage"
PDF_PATH=
UPLOAD_PATH=
BACKUP_PATH=
LOG_PATH=

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
# development | production | test
NODE_ENV="development"
