// Outmat Propostas — Prisma schema (Sprint 0)
//
// IMPORTANTE (Sprint 0): os models são APENAS ESTRUTURAIS.
// Não há regras de negócio nem os campos de domínio definitivos.
// Cada model carrega somente id, timestamps, o vínculo relacional essencial
// e, quando faz sentido, um identificador `nome` (necessário para o seed/tabelas).
// A expansão dos campos ocorrerá nas próximas Sprints via migrations incrementais,
// sem alteração estrutural das camadas da aplicação.
//
// Docs de arquitetura: ARCHITECTURE.md

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// Discriminador do modelo de proposta.
/// COMERCIAL    -> produtos + serviços + módulos opcionais (ex.: Wi-Fi, Som).
/// SIMPLIFICADA -> apenas produtos (nunca serviços, nunca módulos).
/// As regras de negócio serão implementadas nas próximas Sprints.
enum ModeloProposta {
  COMERCIAL
  SIMPLIFICADA
}

/// Tipo de pessoa do cliente.
enum TipoPessoa {
  PF
  PJ
}

/// Status oficiais da proposta (ciclo de vida). Ver DECISIONS.md ADR-0204.
enum StatusProposta {
  RASCUNHO
  EMITIDA
  CANCELADA
}

/// Motivo do cancelamento (obrigatório ao cancelar). ADR-0203.
enum MotivoCancelamento {
  CLIENTE_DESISTIU
  CONCORRENCIA
  PROJETO_CANCELADO
  ERRO_PROPOSTA
  PROPOSTA_SUBSTITUIDA
  OUTRO
}

/// Eventos de auditoria da proposta. ADR-0204.
enum EventoAuditoria {
  CRIACAO
  ALTERACAO
  NOVA_REVISAO
  DUPLICACAO
  MUDANCA_STATUS
  EMISSAO
  CANCELAMENTO
}

/// Tipo de item da revisão. Nesta Sprint só PRODUTO é usado; SERVICO já
/// preparado para a próxima Sprint (ADR-0207).
enum TipoItemProposta {
  PRODUTO
  SERVICO
}

/// Como o desconto da proposta é interpretado (ADR-0220).
enum TipoDesconto {
  VALOR
  PERCENTUAL
}

/// Tipo do serviço complementar da proposta (Sprint 2.9.1). Estrutura preparada
/// para receber novos tipos no futuro SEM alteração de banco. NÃO representa o
/// "Projeto de Automação" (que é o Conteúdo/Revisão) — é uma entidade paralela.
enum TipoServicoProposta {
  SOM
  WIFI
}

// ---------------------------------------------------------------------------
// Cadastros base
// ---------------------------------------------------------------------------

model Cliente {
  id         String     @id @default(cuid())
  ativo      Boolean    @default(true)
  tipoPessoa TipoPessoa @default(PF)

  /// Obrigatório quando PF (validado no Zod).
  nome String?
  /// Obrigatório quando PJ (validado no Zod).
  empresa String?

  /// Opcional; ÚNICO quando informado (nulos não conflitam no PostgreSQL).
  cpfCnpj String? @unique

  /// Documento secundário opcional (ADR-0224): RG (PF) ou Inscrição Estadual
  /// (PJ). Exibido conforme o tipo de pessoa; sem unicidade.
  rg                String?
  inscricaoEstadual String?

  cep         String?
  endereco    String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?

  telefone    String?
  email       String?
  observacoes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  propostas Proposta[]

  @@index([ativo])
  @@map("clientes")
}

model Produto {
  id           String  @id @default(cuid())
  ativo        Boolean @default(true)
  codigo       String  @unique
  descricao    String
  /// Unidade de medida (UN, MT, CX, RL, L, KG…). Origem do snapshot do item.
  unidade      String  @default("UN")
  valorProduto Decimal @db.Decimal(12, 2)
  /// Pode ser zero.
  valorServico Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Itens de proposta que referenciam este produto (regra de exclusão ADR-0104).
  itens PropostaItem[]

  @@index([ativo])
  @@map("produtos")
}

model Vendedor {
  id       String  @id @default(cuid())
  ativo    Boolean @default(true)
  nome     String
  telefone String?
  email    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  propostas Proposta[]

  @@index([ativo])
  @@map("vendedores")
}

// ---------------------------------------------------------------------------
// Propostas — hierarquia: Proposta > Revisão > Seção > Item
// ---------------------------------------------------------------------------

model Proposta {
  id String @id @default(cuid())

  /// Numeração sequencial da proposta (sequência do PostgreSQL, inicia em 1001).
  /// Nunca reutilizada; canceladas mantêm o número. Ver DECISIONS.md ADR-0201.
  proposalNumber Int @unique @default(autoincrement())

  /// Tipo/modelo da proposta (apenas persistência nesta Sprint). ADR-0205.
  modelo ModeloProposta @default(COMERCIAL)

  /// Ciclo de vida (ADR-0204). Cancelada apenas via ação Cancelar (ADR-0203).
  status StatusProposta @default(RASCUNHO)

  /// Nome do projeto (ADR-0227). Texto livre pertencente à Proposta.
  nomeProjeto String?

  /// Validade em dias (nasce com 5; usuário pode alterar).
  validadeDias Int @default(5)

  /// Observações internas (NUNCA no PDF/cliente).
  obsInternas String? @db.Text
  /// Observações da proposta (futuro PDF).
  obsProposta String? @db.Text

  /// Desconto da proposta (ADR-0220). Modelagem separada de tipo/valor; o total
  /// é derivado (nunca persistido). Congelamento por-revisão fica para o PDF.
  tipoDesconto  TipoDesconto @default(VALOR)
  valorDesconto Decimal      @default(0) @db.Decimal(12, 2)

  /// Frete da proposta (ADR-0221). Valor informado manualmente (≥ 0); compõe o
  /// Total da Proposta (derivado, nunca persistido).
  frete Decimal @default(0) @db.Decimal(12, 2)

  /// Informações comerciais finais da proposta (ADR-0222). Texto livre; não
  /// entram em cálculo/total. Serão usadas no PDF (Sprint 2.7).
  /// `previsaoInstalacao` só é exibido no modelo Completa (apresentação).
  formaPagamento     String? @db.Text
  previsaoInstalacao String? @db.Text
  /// Observações comerciais e técnicas (multilinha; futuro PDF).
  obsComerciais String? @db.Text
  obsTecnicas   String? @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  /// Datas de status — carimbadas apenas na 1ª transição; nunca sobrescritas.
  emitidaAt   DateTime?
  canceladaAt DateTime?

  /// Cancelamento (ADR-0203). obsCancelamento obrigatório quando OUTRO.
  motivoCancelamento MotivoCancelamento?
  obsCancelamento    String?             @db.Text

  /// Cliente pode ser nulo APENAS enquanto o rascunho está sendo montado
  /// (fluxo workspace-first). Regra de negócio: proposta válida/emitida SEMPRE
  /// tem cliente — garantido pela guarda de emissão. ADR-0210+ (refino 2.3).
  clienteId  String?
  cliente    Cliente?  @relation(fields: [clienteId], references: [id])
  vendedorId String?
  vendedor   Vendedor? @relation(fields: [vendedorId], references: [id])

  /// Aponta para a revisão ATUAL da proposta (evita consultar/recalcular a
  /// última revisão a cada acesso). Relacionamento 1:1 opcional.
  currentRevisionId String?          @unique
  currentRevision   PropostaRevisao? @relation("PropostaRevisaoAtual", fields: [currentRevisionId], references: [id])

  revisoes   PropostaRevisao[]   @relation("PropostaRevisoes")
  auditorias PropostaAuditoria[]

  /// Serviços complementares (Sprint 2.9.1). Pertencem à Proposta (não à
  /// revisão) e NÃO entram nos cálculos da proposta nesta Sprint.
  servicos PropostaServico[]

  @@index([clienteId])
  @@index([vendedorId])
  @@index([status])
  @@map("propostas")
}

/// Trilha de auditoria da proposta (sem tela nesta Sprint). ADR-0204.
model PropostaAuditoria {
  id String @id @default(cuid())

  propostaId String
  proposta   Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)

  evento         EventoAuditoria
  /// Número da revisão vigente no momento do evento (quando aplicável).
  revisionNumber Int?
  observacao     String? @db.Text

  createdAt DateTime @default(now())

  @@index([propostaId])
  @@map("proposta_auditorias")
}

model PropostaRevisao {
  id String @id @default(cuid())

  /// Número inteiro da revisão (0, 1, 2, ...). O banco guarda APENAS o inteiro;
  /// a interface é responsável por exibir "Rev.0", "Rev.1" etc.
  revisionNumber Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// Momento em que ESTA revisão foi emitida (Gerar PDF). Congela a versão e
  /// alimenta o histórico/PDF por revisão. Null enquanto rascunho.
  emittedAt DateTime?

  propostaId String
  proposta   Proposta @relation("PropostaRevisoes", fields: [propostaId], references: [id], onDelete: Cascade)

  /// Back-relation do vínculo "revisão atual" em Proposta.
  propostaAtual Proposta? @relation("PropostaRevisaoAtual")

  secoes PropostaSecao[]

  @@unique([propostaId, revisionNumber])
  @@index([propostaId])
  @@map("proposta_revisoes")
}

/// Seção = agrupador NEUTRO de itens.
/// Exemplos válidos: "Sala", "Cozinha", "Casa 92", "Apartamento Flávio",
/// "Área Externa", "Recepção", "Piso Superior".
/// NÃO representa obrigatoriamente um "ambiente" — NUNCA tratar como Ambiente internamente.
model PropostaSecao {
  id        String   @id @default(cuid())
  /// Nome do agrupador NEUTRO (ex.: "Sala", "Cozinha"). Nunca "Ambiente".
  nome      String
  /// Ordem contígua (0,1,2…) dentro da revisão. ADR-0208.
  ordem     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  revisaoId String
  revisao   PropostaRevisao @relation(fields: [revisaoId], references: [id], onDelete: Cascade)

  itens PropostaItem[]

  @@index([revisaoId])
  @@map("proposta_secoes")
}

model PropostaItem {
  id        String           @id @default(cuid())
  tipo      TipoItemProposta @default(PRODUTO)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  secaoId String
  secao   PropostaSecao @relation(fields: [secaoId], references: [id], onDelete: Cascade)

  /// Vínculo com o cadastro (navegável). RESTRICT: produto usado não é excluído
  /// (ADR-0104/0207). Itens de PRODUTO sempre preenchem; nulo previsto p/ SERVICO.
  produtoId String?
  produto   Produto? @relation(fields: [produtoId], references: [id], onDelete: Restrict)

  /// Snapshot imutável do produto no momento (ADR-0207).
  codigo       String
  descricao    String
  unidade      String
  valorProduto Decimal @db.Decimal(12, 2)
  valorServico Decimal @db.Decimal(12, 2)

  /// Quantidade (permite frações — cabo, metros, litros…).
  quantidade Decimal @db.Decimal(12, 3) @default(1)
  /// Ordem contígua (0,1,2…) dentro da seção. ADR-0208.
  ordem      Int     @default(0)

  @@index([secaoId])
  @@index([produtoId])
  @@map("proposta_itens")
}

/// Serviço complementar da proposta (Sprint 2.9.1). Entidade única e genérica
/// para qualquer tipo de serviço (hoje SOM e WIFI); novos tipos entram só no
/// enum, sem mudança estrutural. Independente do Conteúdo/Automação e do PDF.
/// Nesta Sprint NÃO entra em subtotal/desconto/frete/total (isso fica p/ 2.9.2).
/// `valorTotal` é gravado (produtos + serviços), calculado no servidor.
/// Único por (proposta, tipo): no máximo um SOM e um WIFI por proposta.
model PropostaServico {
  id String @id @default(cuid())

  propostaId String
  proposta   Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)

  tipo      TipoServicoProposta
  descricao String?             @db.Text

  valorProdutos Decimal @default(0) @db.Decimal(12, 2)
  valorServicos Decimal @default(0) @db.Decimal(12, 2)
  /// Derivado (produtos + serviços); persistido por decisão da Sprint 2.9.1.
  valorTotal    Decimal @default(0) @db.Decimal(12, 2)

  /// Ordem contígua (0,1,2…) de exibição dentro da proposta.
  ordem     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([propostaId, tipo])
  @@index([propostaId])
  @@map("proposta_servicos")
}

// ---------------------------------------------------------------------------
// Configuração do sistema — SINGLETON (existe apenas UM registro)
// ---------------------------------------------------------------------------

/// Registro único de configuração da aplicação.
/// Ponto ÚNICO de expansão futura, SEM alteração estrutural de camadas:
/// dados da empresa, logo, endereço, telefones, WhatsApp, email, site,
/// redes sociais, rodapé do PDF, textos institucionais, templates,
/// caminhos de armazenamento e configurações gerais.
/// Esses campos serão adicionados nas próximas Sprints via migration incremental.
model ConfiguracaoSistema {
  /// id fixo garante a natureza singleton (sempre "singleton").
  id String @id @default("singleton")

  // Dados da empresa
  nomeEmpresa       String?
  razaoSocial       String?
  cnpj              String?
  /// Inscrição Estadual da empresa (ADR-0225).
  inscricaoEstadual String?

  // Endereço
  cep         String?
  endereco    String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?

  // Contatos
  telefone String?
  whatsapp String?
  email    String?
  site     String?

  // Identidade visual
  logo          String?
  corPrimaria   String?
  corSecundaria String?

  // Textos institucionais
  textoQuemSomos     String? @db.Text
  textoFinalProposta String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("configuracao_sistema")
}
